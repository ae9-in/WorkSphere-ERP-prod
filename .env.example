# ─────────────────────────────────────────────────────────
# WorkSphere ERP — Environment Variables
# Copy this file to apps/api/.env and fill in your values
# ─────────────────────────────────────────────────────────

# ── SERVER ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── DATABASE ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/worksphere-erp
REDIS_URL=redis://localhost:6379

# ── AUTH ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-256-bit-random-secret
JWT_REFRESH_SECRET=change-me-to-a-different-256-bit-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CLOUDINARY ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── EMAIL (SMTP) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@worksphere.com

# ── SMS (optional) ────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── ENCRYPTION ────────────────────────────────────────────
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string-here

# ── FEATURE FLAGS ─────────────────────────────────────────
FF_BIOMETRIC_ATTENDANCE=false
FF_WHATSAPP_NOTIFICATIONS=false
FF_AI_INSIGHTS=false
FF_GOOGLE_SSO=false
