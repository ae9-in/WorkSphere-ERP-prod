# ──────────────────────────────────────────────────────────────────────────────
# WorkSphere ERP — Environment Variables Configuration
# Copy this file to `.env` in the project root (and apps/api/.env for local venv).
# ──────────────────────────────────────────────────────────────────────────────

# ── 1. CORE SERVER SETTINGS ───────────────────────────────────────────────────
# Node Environment (development / production / test)
# Required: Yes | Default: development | Security: Low
NODE_ENV=development

# API port mapping
# Required: Yes | Default: 5000 | Security: Low
PORT=5000

# Backend URL mapping
# Required: Yes | Default: http://localhost:5000 | Security: Low
BACKEND_URL=http://localhost:5000

# Frontend Client URL mapping
# Required: Yes | Default: http://localhost:5173 | Security: Low
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# CORS Origin Allowed
# Required: Yes | Default: http://localhost:5173 | Security: Low
CORS_ORIGIN=http://localhost:5173

# Log Level (debug / info / warning / error)
# Required: Optional | Default: info | Security: Low
LOG_LEVEL=info


# ── 2. DATABASE CONFIGURATIONS ────────────────────────────────────────────────
# PostgreSQL Connection URL
# Required: Yes | Default: postgresql://postgres:postgres@localhost:5432/worksphere_erp
# Security: HIGH (Contains db credentials)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worksphere_erp

# PostgreSQL Server Port
# Required: Optional | Default: 5432 | Security: Low
DATABASE_PORT=5432

# MongoDB Connection URI (Optional / Legacy modules)
# Required: Optional | Default: mongodb://localhost:27017/worksphere-erp | Security: HIGH
MONGODB_URI=mongodb://localhost:27017/worksphere-erp

# Valkey URL (Redis-protocol compatible in-memory datastore for cache, sessions, rate-limiting)
# Required: Yes | Default: redis://localhost:6379 | Security: MEDIUM
# Docker Compose: redis://valkey:6379 | Local: redis://localhost:6379
VALKEY_URL=redis://localhost:6379

# Valkey Host
# Required: Optional | Default: localhost | Security: Low
VALKEY_HOST=localhost

# Valkey Port
# Required: Optional | Default: 6379 | Security: Low
VALKEY_PORT=6379

# Valkey Password (leave empty for local dev)
# Required: Optional | Default: (empty) | Security: HIGH (set in production)
VALKEY_PASSWORD=

# Cache URL alias — used by cache/session/queue services
# Required: Yes | Default: redis://localhost:6379 | Security: MEDIUM
CACHE_URL=redis://localhost:6379

# Session Store URL alias
# Required: Yes | Default: redis://localhost:6379 | Security: MEDIUM
SESSION_STORE_URL=redis://localhost:6379

# Queue URL alias
# Required: Yes | Default: redis://localhost:6379 | Security: MEDIUM
QUEUE_URL=redis://localhost:6379


# ── 3. AUTHENTICATION & SECURITY ─────────────────────────────────────────────
# General JWT Secret (alias/compatibility mapping)
# Required: Optional | Security: CRITICAL
JWT_SECRET=44ef6e8b4e7235a963cfdb56ef6d7f02dcd04e0eef7f0d046fbc9e7a9e6bc7jl
# JWT Secret Key for Access Tokens (Generate a secure random 64-char key)
# Required: Yes | Security: CRITICAL
JWT_ACCESS_SECRET=44ef6e8b4e7235a963cfdb56ef6d7f02dcd04e0eef7f0d046fbc9e7a9e6bc7jl

# JWT Secret Key for Refresh Tokens (Generate a different secure 64-char key)
# Required: Yes | Security: CRITICAL
JWT_REFRESH_SECRET=de4ee4f0e0dbef6d0e7a8fbce0e0ee0c4ef6b0ee04fbc8ea9eb0ee047fd0pnqd

# JWT Access Token Lifetime (e.g. 15m, 1h, 7d)
# Required: Yes | Default: 7d | Security: Low
JWT_ACCESS_EXPIRES=7d
ACCESS_TOKEN_EXPIRY=7d

# JWT Refresh Token Lifetime (e.g. 7d, 30d)
# Required: Yes | Default: 30d | Security: Low
JWT_REFRESH_EXPIRES=30d
REFRESH_TOKEN_EXPIRY=30d

# Session Cookie Secret Key
# Required: Optional | Default: change-me-session-secret-key-9921 | Security: HIGH
SESSION_SECRET=change-me-session-secret-key-9921

# Data Encryption Key (32-byte hexadecimal string for field-level encryption)
# Required: Yes | Default: 1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d | Security: CRITICAL
ENCRYPTION_KEY=1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d


# ── 4. CLOUDINARY (FILE STORAGE INTEGRATION) ──────────────────────────────────
# Required for employee profile photos and document uploads
# Required: Optional (Mocked if empty) | Security: HIGH
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# ── 5. EMAIL SMTP CONFIGURATIONS ──────────────────────────────────────────────
# Mail server setup for approval flows and notification alerts
# Required: Yes | Default: smtp.mailtrap.io | Security: MEDIUM
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=fake_smtp_user
SMTP_USER=fake_smtp_user
SMTP_PASSWORD=fake_smtp_password
SMTP_PASS=fake_smtp_password
SMTP_FROM=noreply@worksphere.com
EMAIL_FROM=noreply@worksphere.com


# ── 6. TELEPHONY & MESSAGING (TWILIO & WHATSAPP) ──────────────────────────────
# Twilio credentials for SMS dispatches (optional)
# Required: Optional | Security: HIGH
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=your_twilio_phone_number
TWILIO_FROM_NUMBER=+1234567890

# WhatsApp business integration (optional)
# Required: Optional | Security: HIGH
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_VERIFY_TOKEN=your_meta_verify_token
META_ACCESS_TOKEN=your_meta_access_token


# ── 7. PAYMENT PROCESSORS (STRIPE & RAZORPAY) ──────────────────────────────────
# Subscriptions and payroll client payouts billing gateways (optional)
# Required: Optional | Security: HIGH
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret


# ── 8. CLOUD STORAGE (AWS & AZURE) ────────────────────────────────────────────
# Object store integration fallback for document storage (optional)
# Required: Optional | Security: HIGH
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET=your_aws_secret_key
AWS_BUCKET=worksphere-document-bucket
AWS_REGION=us-east-1
AZURE_STORAGE=your_azure_storage_connection_string


# ── 9. MAPS & LOCATION API SERVICES ───────────────────────────────────────────
# Mapping coordinates for SCM fleet delivery sequences (optional)
# Required: Optional | Security: MEDIUM
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_TOKEN=your_mapbox_token


# ── 10. AI ENGINE & INTEGRATIONS ──────────────────────────────────────────────
# Token credentials for interview evaluations and analytics (optional)
# Required: Optional (Mocked if empty) | Security: HIGH
GOOGLE_GEMINI_KEY=your_google_gemini_key
OPENAI_API_KEY=your_openai_api_key
OPENAI_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
HF_API_KEY=your_huggingface_api_key

# Langchain Tracing integration (optional)
# Required: Optional | Default: false | Security: Low
LANGCHAIN_TRACING=false


# ── 11. TELEMETRY & APM MONITORING ────────────────────────────────────────────
# Required: Optional | Security: MEDIUM
SENTRY_DSN=your_sentry_dsn_url
PROMETHEUS=false
GRAFANA=false


# ── 12. OAUTH SOCIAL IDENTITY PROVIDERS ───────────────────────────────────────
# Google SSO client IDs
# Required: Optional | Security: HIGH
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret


# ── 13. FILE DIRECTORIES ──────────────────────────────────────────────────────
# Required: Optional | Security: Low
UPLOAD_DIRECTORY=./uploads
TEMP_DIRECTORY=./tmp


# ── 14. FEATURE FLAGS ─────────────────────────────────────────────────────────
# Enable or disable platform features
# Required: Yes | Security: Low
FF_BIOMETRIC_ATTENDANCE=true
FF_WHATSAPP_NOTIFICATIONS=false
FF_AI_INSIGHTS=true
FF_GOOGLE_SSO=false


# ── 15. FRONTEND PUBLIC ENVIRONMENT VARIABLES ──────────────────────────────────
# Prefix with NEXT_PUBLIC_ to expose to Next.js Client browser bundle
# Required: Yes | Security: Low
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SOCKET_URL=ws://localhost:5000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key
