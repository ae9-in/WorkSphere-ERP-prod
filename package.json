{
  "name": "worksphere-erp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" npm run build --workspace=apps/web",
    "build:web": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "test": "npm run test --workspace=apps/web"

  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
